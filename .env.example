# SQS and DynamoDB (LocalStack – same endpoint for both)
SQS_ENDPOINT=http://localhost:4566
# Set after: terraform output -raw queue_a_url
QUEUE_A_URL=http://localhost:4566/000000000000/queue-a
# Set after: terraform output -raw queue_b_url
QUEUE_B_URL=http://localhost:4566/000000000000/queue-b

# Optional: backend-a uses PORT=3001, backend-b uses PORT=3002
# PORT=3001
# PORT=3002
